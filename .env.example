# ─── BANCO DE DADOS ──────────────────────────────────────────────────────────
# SQLite local (padrão para desenvolvimento)
DATABASE_URL="file:./dev.db"

# PostgreSQL (produção) — descomente e preencha quando migrar:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/loja_mvp"

# ─── NEXTAUTH ────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-com-openssl-rand-base64-32-e-cole-aqui"

# ─── GOOGLE OAUTH ────────────────────────────────────────────────────────────
# Crie em: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="seu-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu-google-client-secret"

# ─── MERCADO PAGO ────────────────────────────────────────────────────────────
# Credenciais de PRODUÇÃO (para receber pagamentos reais)
MERCADOPAGO_PUBLIC_KEY="APP_USR-f123f2c8-a08c-423f-a7b3-447ebb02e864"
MERCADOPAGO_ACCESS_TOKEN="APP_USR-7933412573159753-032814-4f0585a5235cf1ddc6db260a1b34c440-442158337"

# ─── CLOUDINARY (upload de imagens do admin) ─────────────────────────────────
